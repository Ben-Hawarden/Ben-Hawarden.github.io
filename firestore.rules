rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only the admin UID can write. Everyone can read.
    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'b4t5IxeGyLSGyozcweUrBV2fbzc2';
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Analytics — public increment-only views counter.
    // Anyone reading a post can add to the count; everyone can read totals.
    // Acceptable tradeoff for a personal blog (no PII stored).
    match /analytics/{postId} {
      allow read: if true;
      allow write: if true;
    }

    // Everything else: deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
